# SolarAI India — Environment Configuration Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# ═════════════════════════════════════════════
# SUPABASE (Required)
# ═════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — NEVER expose on frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═════════════════════════════════════════════
# NASA POWER API (Required for solar irradiance data)
# ═════════════════════════════════════════════
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# ═════════════════════════════════════════════
# OPENWEATHER API (Required for current weather + forecast)
# ═════════════════════════════════════════════
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ═════════════════════════════════════════════
# OPTIONAL: Rate Limiting
# ═════════════════════════════════════════════
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=3600

# ═════════════════════════════════════════════
# OPTIONAL: Application
# ═════════════════════════════════════════════
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
